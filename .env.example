# Pinterest API v5 access.
# Prefer refresh-token mode for unattended daily GitHub Actions schedules.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REFRESH_TOKEN=

# Optional fallback if you do not want token refresh. Pinterest access tokens expire.
PINTEREST_ACCESS_TOKEN=

# Unsupported fallback: public profile URL or username to parse without Pinterest API.
# Example: https://www.pinterest.com/vitalyzdanevich/pins/
PUBLIC_PROFILE_TO_PARSE_WITHOUT_API=
# Public profile pages to scan. One page is usually about 25 pins.
PUBLIC_PROFILE_MAX_PAGES=3

# Evernote auth token with permission to create notes.
EVERNOTE_AUTH_TOKEN=

# Optional. If omitted, the tool asks Evernote UserStore for your NoteStore URL.
EVERNOTE_NOTE_STORE_URL=
# Optional target notebook by name. Leave both notebook values empty for default notebook.
EVERNOTE_NOTEBOOK_NAME=
# Optional target notebook by GUID. Use only if name lookup is ambiguous.
EVERNOTE_NOTEBOOK_GUID=

# Optional filters and behavior.
PINTEREST_BOARD_IDS=
PINTEREST_FETCH_MODE=boards
PINTEREST_INCLUDE_SECTIONS=true
BACKFILL_EXISTING=false
ATTACH_IMAGES=true
SCRAPE_PIN_COMMENTS=true
MAX_PIN_COMMENTS=25
MAX_PINS_PER_RUN=25
STATE_PATH=state/state.json
DRY_RUN=false
