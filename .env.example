# Pinterest API v5 access.
# Prefer refresh-token mode for unattended daily GitHub Actions schedules.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REFRESH_TOKEN=

# Optional fallback if you do not want token refresh. Pinterest access tokens expire.
PINTEREST_ACCESS_TOKEN=

# Evernote auth token with permission to create notes.
EVERNOTE_AUTH_TOKEN=

# Optional. If omitted, the tool asks Evernote UserStore for your NoteStore URL.
EVERNOTE_NOTE_STORE_URL=
EVERNOTE_NOTEBOOK_GUID=

# Optional filters and behavior.
PINTEREST_BOARD_IDS=
PINTEREST_FETCH_MODE=boards
PINTEREST_INCLUDE_SECTIONS=true
BACKFILL_EXISTING=false
ATTACH_IMAGES=true
MAX_PINS_PER_RUN=25
STATE_PATH=state/state.json
DRY_RUN=false
